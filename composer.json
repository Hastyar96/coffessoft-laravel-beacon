{
    "name": "coffesoft/laravel-beacon",
    "description": "Laravel Project Context Generator — Scan, understand, and export clean context for AI-assisted development",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Coffesoft\\LaravelBeacon\\": "src/"
        }
    },
    "extra": {
      "laravel": {
            "providers": [
                "Coffesoft\\LaravelBeacon\\Providers\\BeaconServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "Hastyar",
            "email": "hastyar.a96@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "illuminate/console": "^9.0 || ^10.0 || ^11.0",
        "illuminate/support": "^9.0 || ^10.0 || ^11.0",
        "spatie/laravel-package-tools": "^1.9"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0 || ^8.0 || ^9.0"
    }
}